generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id  // Supabase auth user.id (UUID)
  email     String   @unique
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        ItemType  @default(NOTE)
  rawInput    String
  title       String
  content     String?
  startAt     DateTime?
  endAt       DateTime?
  deadlineAt  DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, type])
  @@index([userId, startAt])
  @@index([userId, deadlineAt])
}

enum ItemType {
  EVENT
  TASK
  DEADLINE_TASK
  NOTE
  IDEA
}
